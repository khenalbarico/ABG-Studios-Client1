@inject SocialLinks Socials

<footer id="site-footer" class="site-footer">
    <div class="site-footer-inner">
        <div class="site-footer-brand">
            <h3>ABG Studios</h3>
            <p>Book your favorite treatments and stay connected with us through our social channels.</p>
        </div>

        <div class="site-footer-links">
            <h4>Contact Us</h4>
            <div class="social-links">
                <a href="@Socials.Facebook" target="_blank">Facebook</a>
                <a href="@Socials.Instagram" target="_blank">Instagram</a>
                <a href="@Socials.Tiktok" target="_blank">TikTok</a>
                <a href="mailto:@Socials.BusinessEmail">Email</a>
                <a href="tel:@Socials.BusinessPhone">Call Us</a>
            </div>
        </div>
    </div>

    <div class="site-footer-bottom">
        <span>© 2026 ABG Studios. All rights reserved.</span>
    </div>
</footer>

<style>
    .site-footer {
        margin-top: 4rem;
        padding: 2.5rem 1.5rem 1.25rem;
        padding-bottom: calc(1.25rem + env(safe-area-inset-bottom));
        border-top: 1px solid var(--border-soft);
        color: var(--text-secondary);
        font-size: 14px;
    }

    .site-footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 2rem;
    }

    .site-footer-brand h3,
    .site-footer-links h4 {
        margin: 0 0 0.75rem;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text-primary);
    }

    .site-footer-brand p {
        margin: 0;
        color: var(--text-muted);
        line-height: 1.6;
        max-width: 420px;
    }

    .social-links {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

        .social-links a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: color .2s ease;
        }

            .social-links a:hover {
                color: var(--accent);
            }

    .site-footer-bottom {
        max-width: 1200px;
        margin: 2rem auto 0;
        padding-top: 1rem;
        border-top: 1px solid var(--border-soft);
        color: var(--text-muted);
        font-size: 12px;
    }

    @@media (max-width: 700px) {
        .site-footer-inner {
            grid-template-columns: 1fr;
        }
    }
</style>
