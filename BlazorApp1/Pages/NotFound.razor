@page "/not-found"
@layout MainLayout

<PageTitle>Page Not Found — ABG Studios</PageTitle>

<div class="notfound-shell">
    <h3>Page not found</h3>
    <p>Sorry, the content you are looking for does not exist.</p>
    <a class="notfound-home" href="/">Back to services</a>
</div>

<style>
    .notfound-shell {
        min-height: 50dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        text-align: center;
        padding: 2rem 1.25rem;
    }

        .notfound-shell h3 {
            margin: 0;
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: var(--text-primary);
        }

        .notfound-shell p {
            margin: 0;
            color: var(--text-muted);
        }

    .notfound-home {
        margin-top: 14px;
        padding: 11px 20px;
        border-radius: 980px;
        background: var(--button-primary-bg);
        color: var(--button-primary-text);
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        transition: background .2s ease;
    }

        .notfound-home:hover {
            background: var(--accent-hover);
        }
</style>
